#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/escort — API proxy for per-step memory retrieval
#
# Purpose:
#   Transparent proxy between Claude Code and the Anthropic API. Intercepts
#   every POST /v1/messages request (one per reasoning step) and injects
#   relevant memories from crib. During multi-step agentic loops — where no
#   human prompt triggers UserPromptSubmit — this is how fresh context reaches
#   the agent mid-chain.
#
# Usage:
#   bin/escort &
#   ANTHROPIC_BASE_URL=http://127.0.0.1:7710 claude
#
# Environment:
#   ESCORT_PORT           Listen port (default: 7710)
#   ESCORT_UPSTREAM       Upstream API URL (default: https://api.anthropic.com)
#   ESCORT_CRIB           Crib binary path (default: sibling ../../crib/bin/crib)
#   CRIB_DB               Crib database path (crib's default if unset)
#   CRIB_RERANK_THRESHOLD Reranker threshold (passed through to crib if set)
#
# Dependencies: ruby (socket, json, net/http, open3, uri, digest — stdlib only)
#
# Behavior:
#   1. Binds TCPServer on 127.0.0.1:PORT
#   2. Thread-per-connection
#   3. POST /v1/messages: parse body, retrieve memories, inject, forward, stream back
#   4. GET /health: return 200 OK with status JSON
#   5. Everything else: passthrough to upstream unchanged
#   6. Fail-open: any error in retrieval/injection skips injection silently

require 'socket'
require 'json'
require 'net/http'
require 'open3'
require 'uri'
require 'digest'

PORT     = Integer(ENV.fetch('ESCORT_PORT', '7710'))
UPSTREAM = URI.parse(ENV.fetch('ESCORT_UPSTREAM', 'https://api.anthropic.com'))
CRIB     = ENV.fetch('ESCORT_CRIB', File.expand_path('../../crib/bin/crib', __dir__))

FORMATION_INTERVAL = Integer(ENV.fetch('ESCORT_FORMATION_INTERVAL', '300'))
CACHE_MAX          = Integer(ENV.fetch('ESCORT_CACHE_MAX', '50'))
CACHE_PER_SESSION  = 20
TRICK_BIN          = ENV.fetch('ESCORT_TRICK', File.expand_path('../../trick/bin/trick', __dir__))
FORMATION_DISABLED_FLAG = File.join(
  ENV.fetch('ESCORT_STATE_DIR', File.expand_path('../../.state/escort', __dir__)),
  'formation-disabled'
)

# ---------------------------------------------------------------------------
# DedupTracker — per-session deduplication of injected memories
# ---------------------------------------------------------------------------
# Tracks which memory blocks have been injected per Claude Code session.
# Session ID is extracted from body['metadata']['user_id'], which contains
# a unique `session_<UUID>` suffix. Each session gets its own dedup set so
# parallel sessions (different projects, different terminals) don't suppress
# each other's memories. Block-level dedup: the entire crib response is hashed
# as one unit. If the same block was already injected, it is skipped.
# Stale sessions are cleaned after 1 hour of inactivity.

class DedupTracker
  STALE_SECONDS = 3600 # 1 hour

  def initialize
    @sessions = {}  # session_id => { injected: Set<String>, seen_at: Time }
    @mutex = Mutex.new
    start_cleaner
  end

  def seen?(session_id, block_hash)
    @mutex.synchronize do
      entry = @sessions[session_id]
      if entry
        entry[:seen_at] = Time.now
        entry[:injected].include?(block_hash)
      else
        false
      end
    end
  end

  def record(session_id, block_hash)
    @mutex.synchronize do
      entry = @sessions[session_id] ||= { injected: Set.new, seen_at: Time.now }
      entry[:seen_at] = Time.now
      entry[:injected].add(block_hash)
    end
  end

  private

  def start_cleaner
    Thread.new do
      loop do
        sleep 300
        @mutex.synchronize do
          now = Time.now
          @sessions.delete_if { |_, v| now - v[:seen_at] > STALE_SECONDS }
        end
      end
    end
  end
end

# ---------------------------------------------------------------------------
# ConversationCache — bounded per-session message cache for formation
# ---------------------------------------------------------------------------
# Stores recent user messages for background memory extraction. LRU eviction
# when total entries exceed CACHE_MAX or per-session entries exceed
# CACHE_PER_SESSION. Thread-safe via Mutex.

class ConversationCache
  def initialize(max_total: CACHE_MAX, max_per_session: CACHE_PER_SESSION)
    @max_total = max_total
    @max_per_session = max_per_session
    @sessions = {}  # session_id => Array<{query:, timestamp:}>
    @mutex = Mutex.new
    @total = 0
  end

  def append(session_id, query)
    @mutex.synchronize do
      entries = @sessions[session_id] ||= []
      entries << { query: query, timestamp: Time.now }
      @total += 1

      # Per-session eviction
      while entries.length > @max_per_session
        entries.shift
        @total -= 1
      end

      # Global LRU eviction
      while @total > @max_total
        evict_oldest
      end
    end
  end

  def drain(session_id)
    @mutex.synchronize do
      entries = @sessions.delete(session_id)
      if entries
        @total -= entries.length
        entries
      else
        []
      end
    end
  end

  def drain_all
    @mutex.synchronize do
      result = @sessions.dup
      @sessions.clear
      @total = 0
      result
    end
  end

  def size
    @mutex.synchronize { @total }
  end

  def session_ids
    @mutex.synchronize { @sessions.keys.dup }
  end

  private

  def evict_oldest
    oldest_session = nil
    oldest_time = nil

    @sessions.each do |sid, entries|
      next if entries.empty?
      t = entries.first[:timestamp]
      if oldest_time.nil? || t < oldest_time
        oldest_time = t
        oldest_session = sid
      end
    end

    return unless oldest_session
    @sessions[oldest_session].shift
    @total -= 1
    @sessions.delete(oldest_session) if @sessions[oldest_session].empty?
  end
end

# ---------------------------------------------------------------------------
# FormationWorker — background memory extraction from cached conversations
# ---------------------------------------------------------------------------
# Periodically drains the conversation cache and spawns trick as a separate
# process to extract memories and write them to crib. Follows the DedupTracker
# background thread pattern.

class FormationWorker
  def initialize(cache)
    @cache = cache
    start_worker
  end

  def self.formation_enabled?
    !File.exist?(FORMATION_DISABLED_FLAG)
  end

  private

  def start_worker
    Thread.new do
      loop do
        sleep FORMATION_INTERVAL
        run_formation
      rescue => e
        $stderr.puts "escort: formation error: #{e.class}: #{e.message}"
      end
    end
  end

  def run_formation
    return unless self.class.formation_enabled?
    return unless File.executable?(TRICK_BIN)

    all_sessions = @cache.drain_all
    return if all_sessions.empty?

    all_sessions.each do |session_id, entries|
      next if entries.empty?

      # Build JSONL from cached entries
      jsonl = entries.map { |e|
        JSON.generate({
          type: 'user',
          uuid: "formation-#{session_id}-#{e[:timestamp].to_i}",
          timestamp: e[:timestamp].utc.strftime('%Y-%m-%dT%H:%M:%SZ'),
          sessionId: session_id,
          message: { content: e[:query] }
        })
      }.join("\n")

      # Spawn trick as a separate process with timeout
      begin
        env = {}
        env['CRIB_DB'] = ENV['CRIB_DB'] if ENV['CRIB_DB']
        env['TRICK_SESSION_ID'] = "escort-#{session_id}"

        in_r, in_w = IO.pipe
        pid = Process.spawn(env, TRICK_BIN, in: in_r, out: File::NULL, err: File::NULL)
        in_r.close
        in_w.write(jsonl)
        in_w.close

        # Wait with 60s timeout
        deadline = Time.now + 60
        loop do
          _, status = Process.waitpid2(pid, Process::WNOHANG)
          break if status
          if Time.now > deadline
            Process.kill('TERM', pid) rescue nil
            Process.waitpid2(pid) rescue nil
            $stderr.puts "escort: formation timed out for session #{session_id}"
            break
          end
          sleep 0.5
        end

        $stderr.puts "escort: formation completed for session #{session_id} (#{entries.length} entries)"
      rescue => e
        $stderr.puts "escort: formation spawn error: #{e.class}: #{e.message}"
      end
    end
  end
end

# ---------------------------------------------------------------------------
# MemoryRetriever — wraps `crib retrieve` via Process.spawn
# ---------------------------------------------------------------------------
# Passes query text on stdin. Returns a hash with :text (the raw crib output)
# and :hash (SHA256 of the entire block for dedup). Returns nil on any error
# or timeout.

class MemoryRetriever
  TIMEOUT = 10 # seconds

  def retrieve(query)
    return nil if query.nil? || query.strip.empty?

    started_at = Time.now

    env = {}
    env['CRIB_DB'] = ENV['CRIB_DB'] if ENV['CRIB_DB']

    $stderr.puts "escort: crib cmd=#{CRIB} CRIB_DB=#{env['CRIB_DB'] || '(default)'} query_len=#{query.length}"

    in_r, in_w = IO.pipe
    out_r, out_w = IO.pipe
    err_r, err_w = IO.pipe

    pid = Process.spawn(env, CRIB, 'retrieve', in: in_r, out: out_w, err: err_w)
    in_r.close
    out_w.close
    err_w.close

    in_w.write(query)
    in_w.close

    # Poll for process exit with timeout
    deadline = Time.now + TIMEOUT
    status = nil
    loop do
      _, status = Process.waitpid2(pid, Process::WNOHANG)
      break if status
      if Time.now > deadline
        Process.kill('TERM', pid) rescue nil
        sleep 0.1
        Process.kill('KILL', pid) rescue nil
        Process.waitpid2(pid) rescue nil
        [out_r, err_r].each { |io| io.close rescue nil }
        elapsed = ((Time.now - started_at) * 1000).round
        $stderr.puts "escort: crib retrieve timed out (#{TIMEOUT}s, #{elapsed}ms elapsed)"
        return nil
      end
      sleep 0.05
    end

    elapsed = ((Time.now - started_at) * 1000).round

    stdout = out_r.read
    out_r.close
    err_str = err_r.read
    err_r.close

    $stderr.puts "escort: crib exit=#{status.exitstatus} stdout=#{stdout&.bytesize || 0}B stderr=#{err_str&.bytesize || 0}B elapsed=#{elapsed}ms"
    $stderr.puts "escort: crib stderr: #{err_str}" unless err_str.nil? || err_str.empty?

    unless status.success?
      $stderr.puts "escort: crib retrieve failed (exit #{status.exitstatus})"
      return nil
    end

    if stdout.nil? || stdout.strip.empty?
      $stderr.puts "escort: crib returned empty stdout"
      return nil
    end

    text = stdout.strip
    $stderr.puts "escort: crib retrieve completed (#{elapsed}ms, #{text.bytesize} bytes)"
    { text: text, hash: Digest::SHA256.hexdigest(text) }
  rescue => e
    $stderr.puts "escort: crib retrieve error: #{e.class}: #{e.message}"
    nil
  end
end

# ---------------------------------------------------------------------------
# RequestModifier — extracts query and injects memory into request body
# ---------------------------------------------------------------------------
# Query: last 500 chars of text content from the last user-role message.
# Injection: appends a new text content block to the last user-role message's
# content array. String content is normalized to array form first. The memory
# block is a separate content block — never appended to existing text.

module RequestModifier
  module_function

  # Extract a meaningful query from the conversation for crib retrieval.
  #
  # Two cases:
  #
  # 1. Human just typed something — the last user message contains plain text
  #    blocks (not wrapped in XML). Use the human's text.
  #
  # 2. Agentic step — the last user message is tool results and system-reminder
  #    XML only. Use the last assistant message's reasoning text instead. This
  #    reflects what the agent is currently working on, so memories relevant to
  #    the agent's current focus are surfaced.
  #
  # Text blocks entirely wrapped in a single XML element (<system-reminder>,
  # <command-name>, etc.) are filtered as system injections.
  def extract_query(body)
    messages = body['messages']
    return nil unless messages.is_a?(Array) && !messages.empty?

    # Try the last user message for human-authored text.
    last_user = messages.reverse_each.find { |m| m['role'] == 'user' }
    if last_user
      human_text = extract_plain_text(last_user['content'])
      return human_text unless human_text.empty?
    end

    # Agentic step: use the agent's reasoning from the last assistant message.
    last_assistant = messages.reverse_each.find { |m| m['role'] == 'assistant' }
    if last_assistant
      reasoning = extract_assistant_text(last_assistant['content'])
      return reasoning unless reasoning.empty?
    end

    nil
  end

  # Find the human's text in a user message.
  #
  # Claude Code prepends system content (hooks, compaction summaries, command
  # output) and appends the human's input last. So: take the last text block
  # that isn't XML-wrapped. Not all of them — just the last one.
  def extract_plain_text(content)
    case content
    when String
      s = content.strip
      system_injected?(s) ? '' : s
    when Array
      # Walk backward to find the last human text block
      content.reverse_each do |block|
        next unless block.is_a?(Hash) && block['type'] == 'text'
        t = block['text'].to_s.strip
        next if t.empty? || system_injected?(t)
        return t
      end
      ''
    else
      ''
    end
  end

  # Extract text blocks from assistant message content. These are the agent's
  # reasoning — tool_use blocks are skipped, no XML filtering needed.
  def extract_assistant_text(content)
    texts = case content
            when String then [content.strip]
            when Array
              content.filter_map { |block|
                next unless block.is_a?(Hash) && block['type'] == 'text'
                t = block['text'].to_s.strip
                next if t.empty?
                t
              }
            else
              []
            end
    texts.join("\n").strip
  end

  # Returns true if the text appears to be system-injected content.
  # Two checks:
  #   1. Entirely wrapped in a single XML element (<system-reminder>...</system-reminder>)
  #   2. Contains any paired XML tags — system injections embed <example>, <summary>,
  #      <condition>, etc. Human-typed text almost never contains paired XML tags.
  def system_injected?(text)
    # Entirely a single XML element
    return true if text.match?(/\A<([a-zA-Z][\w-]*)\b[^>]*>.*<\/\1>\s*\z/m)
    # Contains any paired XML tags
    return true if text.match?(/<([a-zA-Z][\w-]*)\b[^>]*>.*<\/\1>/m)
    false
  end

  def inject_memory(body, memory_text)
    messages = body['messages']
    return body unless messages.is_a?(Array)

    last_user_idx = messages.rindex { |m| m['role'] == 'user' }
    return body unless last_user_idx

    msg = messages[last_user_idx]
    content = msg['content']

    # Normalize string content to array form
    case content
    when String
      msg['content'] = [
        { 'type' => 'text', 'text' => content },
        { 'type' => 'text', 'text' => memory_text }
      ]
    when Array
      content.push({ 'type' => 'text', 'text' => memory_text })
    end

    body
  end
end

# ---------------------------------------------------------------------------
# StreamForwarder — forwards request to upstream and streams response back
# ---------------------------------------------------------------------------
# Uses Net::HTTP with SSL. Streams response chunks byte-by-byte back to the
# client socket. 300s read timeout for long streaming responses.

module StreamForwarder
  module_function

  def forward(client, method, path, headers, body)
    http = Net::HTTP.new(UPSTREAM.host, UPSTREAM.port)
    http.use_ssl = (UPSTREAM.scheme == 'https')
    http.read_timeout = 300
    http.open_timeout = 30

    req = case method
          when 'GET'    then Net::HTTP::Get.new(path)
          when 'POST'   then Net::HTTP::Post.new(path)
          when 'PUT'    then Net::HTTP::Put.new(path)
          when 'DELETE' then Net::HTTP::Delete.new(path)
          else               Net::HTTP::Post.new(path)
          end

    # Forward headers, skip hop-by-hop
    skip = %w[host connection transfer-encoding content-length]
    headers.each do |k, v|
      req[k] = v unless skip.include?(k.downcase)
    end
    req['host'] = UPSTREAM.host

    if body && !body.empty?
      req.body = body
      req['content-length'] = body.bytesize.to_s
    end

    http.request(req) do |response|
      # Write status line
      client.write("HTTP/1.1 #{response.code} #{response.message}\r\n")

      # Write headers
      response.each_header do |k, v|
        # Skip hop-by-hop headers
        next if %w[transfer-encoding connection].include?(k.downcase)
        client.write("#{k}: #{v}\r\n")
      end
      client.write("\r\n")

      # Stream body
      response.read_body do |chunk|
        client.write(chunk)
      end
    end
  rescue => e
    $stderr.puts "escort: upstream error: #{e.class}: #{e.message}"
    write_error(client, 502, "Upstream error: #{e.message}")
  end

  def write_error(client, code, message)
    body = JSON.generate({ error: { type: 'proxy_error', message: message } })
    client.write("HTTP/1.1 #{code} Bad Gateway\r\n")
    client.write("Content-Type: application/json\r\n")
    client.write("Content-Length: #{body.bytesize}\r\n")
    client.write("Connection: close\r\n")
    client.write("\r\n")
    client.write(body)
  rescue
    # Client may have disconnected
  end
end

# ---------------------------------------------------------------------------
# EscortProxy — TCPServer on 127.0.0.1:PORT, thread-per-connection
# ---------------------------------------------------------------------------

class EscortProxy
  DRAIN_TIMEOUT = 30 # seconds to wait for active connections before forcing restart

  def initialize
    @dedup = DedupTracker.new
    @retriever = MemoryRetriever.new
    @cache = ConversationCache.new
    @formation = FormationWorker.new(@cache)
    @active = 0
    @active_mutex = Mutex.new
  end

  def start
    server = TCPServer.new('127.0.0.1', PORT)
    $stderr.puts "escort: listening on 127.0.0.1:#{PORT}"
    $stderr.puts "escort: upstream #{UPSTREAM}"
    $stderr.puts "escort: crib #{CRIB}"

    start_file_watcher(server)

    loop do
      client = server.accept rescue next
      Thread.new(client) do |c|
        @active_mutex.synchronize { @active += 1 }
        handle_connection(c)
      rescue => e
        $stderr.puts "escort: #{e.class}: #{e.message}"
      ensure
        @active_mutex.synchronize { @active -= 1 }
        c.close rescue nil
      end
    end
  rescue Interrupt
    $stderr.puts "\nescort: shutting down"
  rescue => e
    $stderr.puts "escort: fatal: #{e.message}"
    raise
  end

  private

  def log_request(**fields)
    parts = fields.compact.map { |k, v| "#{k}=#{v}" }
    $stderr.puts "escort: #{parts.join(' ')}"
  end

  def dump_last_user_message(messages)
    last_user = messages.reverse_each.find { |m| m['role'] == 'user' }
    return unless last_user

    content = last_user['content']
    $stderr.puts "escort: === LAST USER MESSAGE DUMP ==="
    case content
    when String
      $stderr.puts "escort: [string] #{content.bytesize} bytes"
      $stderr.puts content
    when Array
      $stderr.puts "escort: #{content.size} content blocks"
      content.each_with_index do |block, i|
        if block.is_a?(Hash)
          type = block['type'] || 'unknown'
          case type
          when 'text'
            text = block['text'].to_s
            $stderr.puts "escort: --- block #{i} type=text #{text.bytesize} bytes ---"
            $stderr.puts text
          when 'tool_result'
            tool_id = block['tool_use_id']
            inner = block['content']
            inner_size = inner.is_a?(String) ? inner.bytesize : inner.to_s.bytesize
            $stderr.puts "escort: --- block #{i} type=tool_result tool_use_id=#{tool_id} #{inner_size} bytes ---"
            $stderr.puts inner.is_a?(String) ? inner : JSON.pretty_generate(inner)
          else
            $stderr.puts "escort: --- block #{i} type=#{type} ---"
            $stderr.puts JSON.pretty_generate(block)
          end
        else
          $stderr.puts "escort: --- block #{i} (not a hash) ---"
          $stderr.puts block.inspect
        end
      end
    end
    $stderr.puts "escort: === END DUMP ==="
  end

  def dump_last_assistant_message(messages)
    last_asst = messages.reverse_each.find { |m| m['role'] == 'assistant' }
    unless last_asst
      $stderr.puts "escort: === NO ASSISTANT MESSAGE ==="
      return
    end

    content = last_asst['content']
    $stderr.puts "escort: === LAST ASSISTANT MESSAGE DUMP ==="
    case content
    when String
      $stderr.puts "escort: [string] #{content.bytesize} bytes"
      $stderr.puts content
    when Array
      $stderr.puts "escort: #{content.size} content blocks"
      content.each_with_index do |block, i|
        if block.is_a?(Hash)
          type = block['type'] || 'unknown'
          case type
          when 'text'
            text = block['text'].to_s
            $stderr.puts "escort: --- block #{i} type=text #{text.bytesize} bytes ---"
            $stderr.puts text
          when 'tool_use'
            $stderr.puts "escort: --- block #{i} type=tool_use name=#{block['name']} ---"
          else
            $stderr.puts "escort: --- block #{i} type=#{type} ---"
          end
        end
      end
    end
    $stderr.puts "escort: === END ASSISTANT DUMP ==="
  end

  def start_file_watcher(server)
    path = File.expand_path(__FILE__)
    mtime = File.mtime(path)
    Thread.new do
      loop do
        sleep 2
        current = File.mtime(path) rescue next
        next if current == mtime

        $stderr.puts "escort: code changed, draining..."
        # Stop accepting new connections — supervisor will start a fresh worker
        server.close rescue nil

        # Wait for active connections to finish
        deadline = Time.now + DRAIN_TIMEOUT
        loop do
          count = @active_mutex.synchronize { @active }
          break if count == 0
          if Time.now > deadline
            $stderr.puts "escort: drain timeout (#{count} active), exiting anyway"
            break
          end
          sleep 0.25
        end

        $stderr.puts "escort: worker exiting for restart"
        exit(0)
      end
    end
  end

  def handle_connection(client)
    request_line = client.gets("\n")
    return unless request_line

    method, path, = request_line.split(' ', 3)
    return unless method && path

    headers = read_headers(client)
    body_raw = read_body(client, headers)

    # Health check
    if method == 'GET' && path == '/health'
      serve_health(client)
      return
    end

    # Intercept POST /v1/messages
    if method == 'POST' && path =~ %r{^/v1/messages(\?|$)}
      handle_messages(client, method, path, headers, body_raw)
    else
      # Passthrough
      StreamForwarder.forward(client, method, path, headers, body_raw)
    end
  end

  def handle_messages(client, method, path, headers, body_raw)
    body = nil
    begin
      body = JSON.parse(body_raw) if body_raw && !body_raw.empty?
    rescue JSON::ParserError => e
      $stderr.puts "escort: JSON parse error, passing through: #{e.message}"
    end

    # If we can't parse the body, pass through unmodified
    unless body.is_a?(Hash) && body['messages'].is_a?(Array)
      StreamForwarder.forward(client, method, path, headers, body_raw)
      return
    end

    messages = body['messages']
    session_id = extract_session_id(body)

    # Dump message structure for debugging.
    dump_last_user_message(messages)
    dump_last_assistant_message(messages)

    query = RequestModifier.extract_query(body)

    # Shortcut: no query or no session → passthrough
    unless query && session_id
      log_request(messages: messages.size, model: body['model'], query: nil, action: 'passthrough')
      $stderr.puts "escort: query_text: (none)" unless query
      StreamForwarder.forward(client, method, path, headers, body_raw)
      return
    end

    $stderr.puts "escort: query_text: #{query}"

    # Cache for background formation
    @cache.append(session_id, query)

    started_at = Time.now
    result = @retriever.retrieve(query)
    crib_ms = ((Time.now - started_at) * 1000).round

    if result && !@dedup.seen?(session_id, result[:hash])
      body = RequestModifier.inject_memory(body, result[:text])
      @dedup.record(session_id, result[:hash])
      modified_raw = JSON.generate(body)
      log_request(messages: messages.size, model: body['model'], query: query.length,
                  crib_ms: crib_ms, injected: result[:text].bytesize, action: 'injected')
      $stderr.puts result[:text]
      StreamForwarder.forward(client, method, path, headers, modified_raw)
    elsif result
      log_request(messages: messages.size, model: body['model'], query: query.length,
                  crib_ms: crib_ms, action: 'dedup')
      StreamForwarder.forward(client, method, path, headers, body_raw)
    else
      log_request(messages: messages.size, model: body['model'], query: query.length,
                  crib_ms: crib_ms, action: 'no_results')
      StreamForwarder.forward(client, method, path, headers, body_raw)
    end
  end

  # Extract session UUID from metadata.user_id field.
  # Format: "user_<hash>_account_<uuid>_session_<uuid>"
  def extract_session_id(body)
    user_id = body.dig('metadata', 'user_id')
    return nil unless user_id.is_a?(String)

    match = user_id.match(/session_([0-9a-f-]+)\z/)
    match ? match[1] : nil
  end

  def serve_health(client)
    crib_ok = File.executable?(CRIB)
    body = JSON.generate({
      status: 'ok',
      port: PORT,
      upstream: UPSTREAM.to_s,
      crib: CRIB,
      crib_available: crib_ok,
      formation_enabled: FormationWorker.formation_enabled?
    })
    client.write("HTTP/1.1 200 OK\r\n")
    client.write("Content-Type: application/json\r\n")
    client.write("Content-Length: #{body.bytesize}\r\n")
    client.write("Connection: close\r\n")
    client.write("\r\n")
    client.write(body)
  end

  def read_headers(client)
    headers = {}
    loop do
      line = client.gets("\n")
      break if line.nil? || line.strip.empty?
      key, value = line.split(':', 2)
      headers[key.strip.downcase] = value.strip if key && value
    end
    headers
  end

  MAX_BODY_SIZE = 10_485_760 # 10 MB — API requests can be large

  def read_body(client, headers)
    length = headers['content-length']&.to_i
    return nil unless length && length > 0
    return nil if length > MAX_BODY_SIZE
    client.read(length)
  end
end

# ---------------------------------------------------------------------------
# Main — supervisor / worker split
# ---------------------------------------------------------------------------
# Supervisor: forks a worker child, waits for it to exit, restarts.
# Worker: runs the actual proxy. Exits on code change (file watcher) or crash.
# The supervisor always re-execs the file, so the worker gets fresh code.

if ENV['ESCORT_WORKER']
  EscortProxy.new.start
else
  $stderr.puts "escort: supervisor starting (pid #{Process.pid})"
  worker_pid = nil

  # Propagate termination signals to the worker.
  # No waitpid in the handler — the main loop is already blocked in waitpid,
  # and re-entering it from a signal handler deadlocks.
  %w[INT TERM].each do |sig|
    Signal.trap(sig) do
      Process.kill(sig, worker_pid) rescue nil if worker_pid
      exit(0)
    end
  end

  failures = 0
  loop do
    started_at = Time.now
    worker_pid = fork do
      ENV['ESCORT_WORKER'] = '1'
      exec(RbConfig.ruby, File.expand_path(__FILE__))
    end
    _, status = Process.waitpid2(worker_pid)

    # If worker ran for >5s, it was healthy — reset backoff
    if Time.now - started_at > 5
      failures = 0
    else
      failures += 1
    end

    delay = [0.5 * (2**failures), 30].min
    $stderr.puts "escort: worker #{worker_pid} exited (#{status}), restarting in #{delay}s..."
    sleep delay
  end
end
